{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(index.html|styles.css|film.css|film.js|robots.txt|sitemap.xml)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "redirects": [
    {
      "source": "/tadapop.apk",
      "destination": "https://github.com/youfun88/tadapop-web/releases/latest/download/tadapop.apk",
      "permanent": false
    }
  ]
}
